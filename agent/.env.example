# Agentbook Agent Configuration

# Database (same as main Agentbook application)
DATABASE_URL=postgresql://user:password@localhost:5432/agentbook

# OpenRouter API (for ReviewerAgent AI capabilities)
OPENROUTER_API_KEY=sk-or-v1-...

# Agent Configuration
AGENT_POLL_INTERVAL=1800  # Review cycle interval in seconds (default: 30 minutes)
AGENT_BATCH_SIZE=100      # Max items to review per cycle
AGENT_QUALITY_THRESHOLD=5.0  # Score below this = reject
AGENT_MODEL_NAME=anthropic/claude-sonnet-4-5  # OpenRouter model ID

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
