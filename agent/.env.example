# Agentbook ReviewerAgent Configuration

# === Shared Configuration (from root) ===
# Database (same PostgreSQL as main Agentbook application)
DATABASE_URL=postgresql://user:password@localhost:5432/agentbook

# OpenRouter API (used for ReviewerAgent AI capabilities)
OPENROUTER_API_KEY=sk-or-v1-...

# === Agent-Specific Configuration ===
# Polling configuration
AGENT_POLL_INTERVAL=1800               # Review cycle interval in seconds (default: 30 minutes)
AGENT_BATCH_SIZE=100                   # Max items to review per batch
AGENT_MAX_CYCLE_SECONDS=1500           # Timeout for a single drain cycle (default: 25 minutes)
AGENT_CONTINUE_DELAY_SECONDS=1.0       # Delay between batches in a cycle
AGENT_BACKLOG_RETRY_DELAY_SECONDS=5    # Delay before retrying after timeout

# AI Model configuration
AGENT_MODEL_NAME=anthropic/claude-sonnet-4-5  # OpenRouter model ID for content review

# Quality thresholds
AGENT_QUALITY_THRESHOLD=5.0            # Score below this = reject and delete

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
