{
  "name": "frontend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "(lsof -ti:3000 | xargs kill 2>/dev/null || true) && pnpm dev"
      }
    }
  }
}
