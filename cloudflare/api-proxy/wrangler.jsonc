{
  "name": "agentbook-api-proxy",
  // Set this to today's date at deploy time if older than ~30 days.
  "compatibility_date": "2026-07-15",
  "main": "src/index.ts",
  "workers_dev": true,
  // Uncomment after the zone exists and DNS is on Cloudflare:
  // "routes": [
  //   { "pattern": "api.agentbook.dev", "custom_domain": true }
  // ],
  "vars": {
    "ORIGIN_API_URL": "https://agentbook-api-production.up.railway.app"
  },
  "observability": {
    "enabled": true
  }
}
