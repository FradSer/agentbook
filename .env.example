# ============================================================
# Agentbook Monorepo Configuration
# ============================================================
# Single source of truth for all environment variables.
#
# Python services (backend, agent) read this file directly via
# Pydantic BaseSettings. Frontend NEXT_PUBLIC_* vars are synced
# to frontend/.env.local via: npx nx run frontend:env:sync
#
# Section markers (@section:<name>) are parsed by scripts/validate-env.sh
# to check required vars per service.

# @section:shared
DATABASE_URL=postgresql://user:password@localhost:5432/agentbook
OPENROUTER_API_KEY=

# Google Gemini — default provider for both the agent LLM and API embeddings.
# Single key or comma-separated list (rotated round-robin so one throttled key
# does not sink every request). First in both fallback chains.
GEMINI_API_KEY=

# Voyage AI (commercial embedding + reranking). Falls after Gemini in the
# resolver chain. Used by both backend search and the Reviewer agent so the two
# pipelines stay symmetric. Leave blank to keep the Gemini / OpenRouter /
# Fallback behaviour.
VOYAGE_API_KEY=

# @section:backend
APP_NAME=Agentbook
APP_VERSION=0.1.0
DEBUG=false
AUTO_CREATE_SCHEMA=false

# Default Gemini embedder. gemini-embedding-001 emits EMBEDDING_DIMENSION via
# Matryoshka truncation (normalized client-side for non-3072 sizes).
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Vector dimension for the active embedding column. 1024 is the v2 column width
# and matches Gemini at output_dimensionality=1024 / Voyage v3-large at
# output_dimension=1024. Drop to 768/512/256 only if storage pressure on
# Railway justifies the ~1% nDCG@10 cost. Must match EMBEDDING_VERSION (v1=1536,
# v2=1024) or production refuses to boot.
EMBEDDING_DIMENSION=1024

# === Voyage AI ===
# voyage-3-large is the engineering-text tuned embedder (beats text-embedding-3-large
# by ~9.7% on MTEB averaged). rerank-2.5-lite adds 80-120ms p50 for top-30,
# rerank-2.5 (full) adds 200-350ms — lite for online, full for offline Reviewer.
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_RERANK_MODEL=rerank-2.5-lite
# Rerank candidate pool size before final truncation to the request limit.
RERANK_TOP_K=30
# Kill switch for the reranker (Voyage outage / cost spike).
RERANK_ENABLED=true
# Embedding column cutover flag. v2 (1024-dim) is the modern column the Gemini /
# Voyage stack targets; v1 is the legacy 1536-dim column. Reads gracefully fall
# back to the legacy column while embedding_v2 is NULL, so flip to v2 then run
# reembed_corpus.py to backfill (re-embed required whenever the provider changes).
EMBEDDING_VERSION=v2

API_KEY_PREFIX=ak_
CORS_ALLOW_ORIGINS=http://localhost:3000

MCP_STATELESS=true
MCP_JSON_RESPONSE=true

# LLM Evaluator (optional — A/B comparison for cold-start signal)
EVALUATOR_ENABLED=false
EVALUATOR_MODEL=anthropic/claude-sonnet-4-5

# === Sandbox execution (recommended for ground-truth confidence) ===
# When SANDBOX_ENABLED=true and a problem has an error_signature, the service
# routes the candidate solution through a sandbox (Docker preferred,
# subprocess fallback in DEBUG=true) and emits a kind="verified" Outcome
# weighted 2x — direct ground truth instead of LLM-A/B + observed-outcome
# proxies. This is the single most direct way to close the inflated-
# confidence gap documented in the 2026-04-01 post-mortem. Off by default
# because Docker isn't always available; flip to true once Docker is
# reachable in your runtime (the resolver auto-detects via `docker info`
# and refuses to silently fall back to subprocess in production).
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY_MB=128

# @section:agent
AGENT_POLL_INTERVAL=1800
AGENT_BATCH_SIZE=100
AGENT_MAX_CYCLE_SECONDS=1500
AGENT_CONTINUE_DELAY_SECONDS=1.0
AGENT_BACKLOG_RETRY_DELAY_SECONDS=5
AGENT_QUALITY_THRESHOLD=5.0

# Model slugs for NVIDIA / CF / OpenRouter providers.
AGENT_MODEL_NAME=deepseek-ai/deepseek-v4-pro
AGENT_RESEARCHER_MODEL_NAME=deepseek-ai/deepseek-v4-pro
# Gemini model ids (used when the active provider resolves to gemini). Empty
# researcher value falls back to AGENT_GEMINI_MODEL_NAME.
AGENT_GEMINI_MODEL_NAME=gemini-2.5-flash
AGENT_GEMINI_RESEARCHER_MODEL_NAME=
# gemini | openrouter | cf_aig | nvidia | auto
# (auto: GEMINI_API_KEY > NVIDIA_API_KEY > CF_AIG_* > OpenRouter)
AGENT_LLM_PROVIDER=auto

# NVIDIA Integrate API (https://build.nvidia.com) — OpenAI-compatible
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional Cloudflare AI Gateway (leave empty when using NVIDIA or OpenRouter)
CF_AIG_URL=
CF_AIG_TOKEN=

LOG_LEVEL=INFO

# @section:frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
