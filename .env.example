# ============================================================
# Agentbook Monorepo Configuration
# ============================================================
# Single source of truth for all environment variables.
#
# Python services (backend, agent) read this file directly via
# Pydantic BaseSettings. Frontend NEXT_PUBLIC_* vars are synced
# to frontend/.env.local via: npx nx run frontend:env:sync
#
# Section markers (@section:<name>) are parsed by scripts/validate-env.sh
# to check required vars per service.

# @section:shared
DATABASE_URL=postgresql://user:password@localhost:5432/agentbook
OPENROUTER_API_KEY=

# Voyage AI (commercial embedding + reranking). When set, takes precedence
# over OpenRouter in the resolver chain. Used by both backend search and the
# Reviewer agent so the two pipelines stay symmetric. Leave blank to keep the
# OpenRouter / Fallback behaviour.
VOYAGE_API_KEY=

# @section:backend
APP_NAME=Agentbook
APP_VERSION=0.1.0
DEBUG=false
AUTO_CREATE_SCHEMA=false

OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Vector dimension for the active embedding column. 1024 matches Voyage v3-large
# at output_dimension=1024 (Matryoshka native). Drop to 768/512/256 only if
# storage pressure on Railway justifies the ~1% nDCG@10 cost.
EMBEDDING_DIMENSION=1024

# === Voyage AI ===
# voyage-3-large is the engineering-text tuned embedder (beats text-embedding-3-large
# by ~9.7% on MTEB averaged). rerank-2.5-lite adds 80-120ms p50 for top-30,
# rerank-2.5 (full) adds 200-350ms — lite for online, full for offline Reviewer.
VOYAGE_EMBEDDING_MODEL=voyage-3-large
VOYAGE_RERANK_MODEL=rerank-2.5-lite
# Rerank candidate pool size before final truncation to the request limit.
RERANK_TOP_K=30
# Kill switch for the reranker (Voyage outage / cost spike).
RERANK_ENABLED=true
# Embedding column cutover flag — flip to v2 only after reembed_corpus.py
# reports >99% coverage on problems.embedding_v2.
EMBEDDING_VERSION=v1

API_KEY_PREFIX=ak_
CORS_ALLOW_ORIGINS=http://localhost:3000

MCP_STATELESS=true
MCP_JSON_RESPONSE=true

# LLM Evaluator (optional — A/B comparison for cold-start signal)
EVALUATOR_ENABLED=false
EVALUATOR_MODEL=anthropic/claude-sonnet-4-5

# === Sandbox execution (recommended for ground-truth confidence) ===
# When SANDBOX_ENABLED=true and a problem has an error_signature, the service
# routes the candidate solution through a sandbox (Docker preferred,
# subprocess fallback in DEBUG=true) and emits a kind="verified" Outcome
# weighted 2x — direct ground truth instead of LLM-A/B + observed-outcome
# proxies. This is the single most direct way to close the inflated-
# confidence gap documented in the 2026-04-01 post-mortem. Off by default
# because Docker isn't always available; flip to true once Docker is
# reachable in your runtime (the resolver auto-detects via `docker info`
# and refuses to silently fall back to subprocess in production).
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY_MB=128

# @section:agent
AGENT_POLL_INTERVAL=1800
AGENT_BATCH_SIZE=100
AGENT_MAX_CYCLE_SECONDS=1500
AGENT_CONTINUE_DELAY_SECONDS=1.0
AGENT_BACKLOG_RETRY_DELAY_SECONDS=5
AGENT_QUALITY_THRESHOLD=5.0

AGENT_MODEL_NAME=anthropic/claude-sonnet-4.5
AGENT_RESEARCHER_MODEL_NAME=minimax/minimax-m2.5

LOG_LEVEL=INFO

# @section:frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
