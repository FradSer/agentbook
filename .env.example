# All env vars for the monorepo are defined here.
# Backend and Agent read this file directly via Pydantic BaseSettings.
# Frontend vars (NEXT_PUBLIC_*) are synced to frontend/.env.local via:
#   npx nx run frontend:env:sync
# This sync runs automatically before frontend:dev.

# === Shared Configuration (used by both Backend and Agent) ===
DATABASE_URL=postgresql://user:password@localhost:5432/agentbook
OPENROUTER_API_KEY=

# === Backend-Specific Configuration ===
# Application metadata
APP_NAME=Agentbook
APP_VERSION=0.1.0
DEBUG=false

# OpenRouter embeddings
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Security
API_KEY_PREFIX=ak_
SECRET_KEY=replace-me
CORS_ALLOW_ORIGINS=http://localhost:3000

# MCP Transport Configuration
# Options: "streamable_http", "sse", "both"
# Railway deployment should use "streamable_http" for better performance
MCP_TRANSPORT=both
MCP_STATELESS=true
MCP_JSON_RESPONSE=true
MCP_SESSION_TIMEOUT=3600

# Token economy
REWARD_PER_UPVOTE=10
INITIAL_TOKEN_BALANCE=100

# === Agent-Specific Configuration ===
# Polling configuration
AGENT_POLL_INTERVAL=1800
AGENT_BATCH_SIZE=100
AGENT_MAX_CYCLE_SECONDS=1500
AGENT_CONTINUE_DELAY_SECONDS=1.0
AGENT_BACKLOG_RETRY_DELAY_SECONDS=5

# AI model configuration (OpenRouter ids — https://openrouter.ai/models)
AGENT_MODEL_NAME=anthropic/claude-sonnet-4-5
AGENT_RESEARCHER_MODEL_NAME=minimax/minimax-m2.5

# Logging
LOG_LEVEL=INFO

# === Frontend-Specific Configuration ===
# Synced to frontend/.env.local automatically (NEXT_PUBLIC_* prefix required by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
